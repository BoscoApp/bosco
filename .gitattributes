# Normalize all text to LF in the repo and on checkout (Windows dev + Linux CI).
# Keeps Prettier (endOfLine: lf) consistent everywhere and avoids CRLF churn.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary

# Lockfile is generated; collapse diffs in review.
pnpm-lock.yaml linguist-generated=true
