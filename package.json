{
	"name": "bosco.kids",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node scripts/generate-calendar.mjs && node scripts/process-media.mjs",
		"build": "vite build && pagefind --site build",
		"preview": "vite preview",
		"serve:build": "sirv build --port 4173 --host",
		"prepare": "svelte-kit sync || echo ''",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . && stylelint \"src/**/*.css\"",
		"format": "prettier --write .",
		"check:offline": "node scripts/check-no-external-urls.mjs build",
		"gen:calendar": "node scripts/generate-calendar.mjs",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "vitest run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"sharp": "^0.35.3",
		"sirv-cli": "^3.0.1",
		"stylelint": "^17.14.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svgo": "^4.0.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@fontsource/atkinson-hyperlegible": "^5.2.8",
		"@fontsource/press-start-2p": "^5.2.7",
		"@pagefind/default-ui": "^1.5.2",
		"zod": "^4.4.3"
	},
	"overrides": {
		"cookie": "^0.7.0"
	}
}
