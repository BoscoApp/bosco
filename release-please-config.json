{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"packages": {
		".": {
			"release-type": "node",
			"changelog-sections": [
				{ "type": "feat", "section": "✨ New Features" },
				{ "type": "fix", "section": "🐛 Fixes" },
				{ "type": "perf", "section": "🚀 Improvements" },
				{ "type": "revert", "section": "🐛 Fixes" },
				{ "type": "refactor", "section": "📊 General Changes" },
				{ "type": "docs", "section": "📊 General Changes" },
				{ "type": "build", "section": "📊 General Changes" },
				{ "type": "ci", "section": "📊 General Changes", "hidden": true },
				{ "type": "chore", "section": "📊 General Changes", "hidden": true }
			]
		}
	}
}
